  <sgraph:Statechart xmi:id="_g8Y7EBwcEeq4Lc5XsD6Vnw" specification="@ParentFirstExecution&#xA;@EventDriven&#xA;&#xA;interface:&#xA;&#x9;var power : integer&#xA;&#x9;in event high&#xA;&#x9;in event low&#xA;&#x9;in event digit : integer&#xA;&#x9;in event timer&#xA;&#x9;in event start&#xA;&#x9;in event stop&#xA;&#x9;in event open&#xA;&#x9;in event close&#xA;&#x9;operation displayTime(t:integer)&#xA;&#x9;operation display(msg:string)&#xA;&#x9;operation clearDisplay()&#xA;&#x9;operation cook()&#xA;&#x9;operation stopCook()&#xA;&#x9;operation beepOn()&#xA;&#x9;operation beepOff()&#xA;&#x9;operation closeDoor()&#xA;&#x9;operation openDoor()&#xA;&#xA;internal:&#xA;&#x9;var time : integer = 0&#xA;&#x9;var numDigits : integer = 0&#xA;&#x9;var wasCooking : boolean = false&#xA;&#x9;var fromState : integer = 0&#xA;&#x9;var blinkCount : integer = 0&#xA;&#x9;" name="microwave">
    <regions xmi:id="_g8gP0xwcEeq4Lc5XsD6Vnw" name="Microwave">
      <vertices xsi:type="sgraph:Entry" xmi:id="_AA000000000000000000001">
        <outgoingTransitions xmi:id="_TT000000000000000000001" target="_SS000000000000000000001"/>
      </vertices>
      <vertices xsi:type="sgraph:State" xmi:id="_SS000000000000000000001" specification="entry /&#xD;&#xA;clearDisplay();&#xD;&#xA;closeDoor();&#xD;&#xA;time = 0;&#xD;&#xA;numDigits = 0;&#xD;&#xA;wasCooking = false;&#xD;&#xA;power = 0;&#xD;&#xA;fromState = 0;&#xD;&#xA;blinkCount = 0" name="Idle" incomingTransitions="_TT000000000000000000001 _TT000000000000000000040 _TT000000000000000000050 _TT000000000000000000060 _TT000000000000000000070 _TT000000000000000000204 _TT000000000000000000202 _TT000000000000000000030 _TT000000000000000000080 _TT000000000000000000100">
        <outgoingTransitions xmi:id="_TT000000000000000000002" specification="high / power = 1; display(&quot;High&quot;)" target="_SS000000000000000000002"/>
        <outgoingTransitions xmi:id="_TT000000000000000000003" specification="low / power = 2; display(&quot;Low&quot;)" target="_SS000000000000000000002"/>
        <outgoingTransitions xmi:id="_TT000000000000000000004" specification="open / fromState = 0" target="_SS000000000000000000006"/>
      </vertices>
      <vertices xsi:type="sgraph:State" xmi:id="_SS000000000000000000002" name="SelectPower" incomingTransitions="_TT000000000000000000002 _TT000000000000000000003 _TT000000000000000000005 _TT000000000000000000006 _TT000000000000000000090 _TT000000000000000000092">
        <outgoingTransitions xmi:id="_TT000000000000000000005" specification="high / power = 1; display(&quot;High&quot;)" target="_SS000000000000000000002"/>
        <outgoingTransitions xmi:id="_TT000000000000000000006" specification="low / power = 2; display(&quot;Low&quot;)" target="_SS000000000000000000002"/>
        <outgoingTransitions xmi:id="_TT000000000000000000007" specification="timer / time = 0; numDigits = 0; clearDisplay()" target="_SS000000000000000000003"/>
        <outgoingTransitions xmi:id="_TT000000000000000000008" specification="open / fromState = 1" target="_SS000000000000000000006"/>
        <outgoingTransitions xmi:id="_TT000000000000000000040" specification="stop" target="_SS000000000000000000001"/>
      </vertices>
      <vertices xsi:type="sgraph:State" xmi:id="_SS000000000000000000003" name="SetTimer" incomingTransitions="_TT000000000000000000007 _TT000000000000000000010 _TT000000000000000000091">
        <outgoingTransitions xmi:id="_TT000000000000000000010" specification="digit [numDigits &lt; 4] / time = time * 10 + valueof(digit); numDigits = numDigits + 1; displayTime(time)" target="_SS000000000000000000003"/>
        <outgoingTransitions xmi:id="_TT000000000000000000011" specification="start [time > 0] / cook(); displayTime(time)" target="_SS000000000000000000004"/>
        <outgoingTransitions xmi:id="_TT000000000000000000012" specification="open / fromState = 2" target="_SS000000000000000000006"/>
        <outgoingTransitions xmi:id="_TT000000000000000000050" specification="stop" target="_SS000000000000000000001"/>
      </vertices>
      <vertices xsi:type="sgraph:State" xmi:id="_SS000000000000000000004" name="Cooking" incomingTransitions="_TT000000000000000000011 _TT000000000000000000013 _TT000000000000000000019">
        <outgoingTransitions xmi:id="_TT000000000000000000013" specification="after 1 s [time > 1] / time = time - 1; displayTime(time)" target="_SS000000000000000000004"/>
        <outgoingTransitions xmi:id="_TT000000000000000000014" specification="after 1 s [time &lt;= 1] / time = 0; stopCook(); blinkCount = 0" target="_SS000000000000000000005"/>
        <outgoingTransitions xmi:id="_TT000000000000000000015" specification="open / stopCook(); wasCooking = true; fromState = 3" target="_SS000000000000000000006"/>
        <outgoingTransitions xmi:id="_TT000000000000000000060" specification="stop / stopCook()" target="_SS000000000000000000001"/>
      </vertices>
      <vertices xsi:type="sgraph:State" xmi:id="_SS000000000000000000005" specification="entry /&#xD;&#xA;beepOn();&#xD;&#xA;display(&quot;Finished&quot;)" name="FinishedOn" incomingTransitions="_TT000000000000000000014 _TT000000000000000000201 _TT000000000000000000095">
        <outgoingTransitions xmi:id="_TT000000000000000000200" specification="after 500 ms" target="_SS000000000000000000008"/>
        <outgoingTransitions xmi:id="_TT000000000000000000016" specification="open / beepOff(); fromState = 4; wasCooking = false" target="_SS000000000000000000006"/>
        <outgoingTransitions xmi:id="_TT000000000000000000070" specification="stop / beepOff()" target="_SS000000000000000000001"/>
      </vertices>
      <vertices xsi:type="sgraph:State" xmi:id="_SS000000000000000000008" specification="entry /&#xD;&#xA;beepOff();&#xD;&#xA;clearDisplay()" name="FinishedOff" incomingTransitions="_TT000000000000000000200 _TT000000000000000000096">
        <outgoingTransitions xmi:id="_TT000000000000000000201" specification="after 500 ms [blinkCount &lt; 4] / blinkCount = blinkCount + 1" target="_SS000000000000000000005"/>
        <outgoingTransitions xmi:id="_TT000000000000000000202" specification="after 500 ms [blinkCount >= 4]" target="_SS000000000000000000001"/>
        <outgoingTransitions xmi:id="_TT000000000000000000203" specification="open / fromState = 5; wasCooking = false" target="_SS000000000000000000006"/>
        <outgoingTransitions xmi:id="_TT000000000000000000204" specification="stop" target="_SS000000000000000000001"/>
      </vertices>
      <vertices xsi:type="sgraph:State" xmi:id="_SS000000000000000000006" specification="entry /&#xD;&#xA;openDoor();&#xD;&#xA;display(&quot;Waiting&quot;)" name="DoorOpen" incomingTransitions="_TT000000000000000000004 _TT000000000000000000008 _TT000000000000000000012 _TT000000000000000000015 _TT000000000000000000016 _TT000000000000000000203 _TT000000000000000000033">
        <outgoingTransitions xmi:id="_TT000000000000000000017" specification="close [wasCooking] / closeDoor(); displayTime(time)" target="_SS000000000000000000007"/>
        <outgoingTransitions xmi:id="_TT000000000000000000090" specification="close [!wasCooking &amp;&amp; fromState == 1 &amp;&amp; power == 1] / closeDoor(); display(&quot;High&quot;)" target="_SS000000000000000000002"/>
        <outgoingTransitions xmi:id="_TT000000000000000000092" specification="close [!wasCooking &amp;&amp; fromState == 1 &amp;&amp; power == 2] / closeDoor(); display(&quot;Low&quot;)" target="_SS000000000000000000002"/>
        <outgoingTransitions xmi:id="_TT000000000000000000091" specification="close [!wasCooking &amp;&amp; fromState == 2] / closeDoor(); displayTime(time)" target="_SS000000000000000000003"/>
        <outgoingTransitions xmi:id="_TT000000000000000000095" specification="close [!wasCooking &amp;&amp; fromState == 4] / closeDoor()" target="_SS000000000000000000005"/>
        <outgoingTransitions xmi:id="_TT000000000000000000096" specification="close [!wasCooking &amp;&amp; fromState == 5] / closeDoor()" target="_SS000000000000000000008"/>
        <outgoingTransitions xmi:id="_TT000000000000000000030" specification="close [!wasCooking &amp;&amp; fromState == 0] / closeDoor()" target="_SS000000000000000000001"/>
        <outgoingTransitions xmi:id="_TT000000000000000000080" specification="stop / closeDoor()" target="_SS000000000000000000001"/>
      </vertices>
      <vertices xsi:type="sgraph:State" xmi:id="_SS000000000000000000007" specification="entry /&#xD;&#xA;closeDoor();&#xD;&#xA;displayTime(time)" name="WaitStart" incomingTransitions="_TT000000000000000000017">
        <outgoingTransitions xmi:id="_TT000000000000000000019" specification="start / cook(); displayTime(time)" target="_SS000000000000000000004"/>
        <outgoingTransitions xmi:id="_TT000000000000000000033" specification="open / wasCooking = true; fromState = 3" target="_SS000000000000000000006"/>
        <outgoingTransitions xmi:id="_TT000000000000000000100" specification="stop" target="_SS000000000000000000001"/>
      </vertices>
    </regions>
  </sgraph:Statechart>
